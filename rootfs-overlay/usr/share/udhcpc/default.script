#!/bin/sh
case "$1" in
    bound|renew)
        ifconfig $interface $ip netmask $subnet
        [ -n "$router" ] && route add default gw $router
        # Write DNS servers from DHCP into resolv.conf; fall back to public DNS
        {
            for server in $dns; do
                echo "nameserver $server"
            done
            [ -z "$dns" ] && echo "nameserver 8.8.8.8"
        } > /tmp/resolv.conf
        ;;
    deconfig)
        ifconfig $interface 0.0.0.0
        ;;
esac
