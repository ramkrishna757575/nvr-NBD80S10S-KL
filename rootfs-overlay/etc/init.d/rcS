#!/bin/sh
mount -t proc none /proc
mount -t sysfs none /sys
mount -t devtmpfs none /dev
mkdir -p /dev/pts
mount -t devpts none /dev/pts
mount -t tmpfs tmpfs /tmp
mount -t tmpfs tmpfs /etc/dropbear

echo "nvr-custom" > /proc/sys/kernel/hostname

echo "Waiting for USB drive..."
for i in 1 2 3 4 5 6 7 8; do
    for dev in /dev/sda1 /dev/sda2 /dev/sdb1 /dev/sdb2; do
        if [ -b "$dev" ]; then
            mkdir -p /mnt/newroot
            if mount $dev /mnt/newroot 2>/dev/null; then
                if [ -x /mnt/newroot/init ] && [ -x /mnt/newroot/bin/sh ]; then
                    echo "Valid rootfs found on $dev, switching root..."
                    mkdir -p /mnt/newroot/oldroot
                    pivot_root /mnt/newroot /mnt/newroot/oldroot &&
                        exec /init
                    echo "pivot_root/exec failed, falling back to flash boot..."
                fi
                umount /mnt/newroot 2>/dev/null
            fi
        fi
    done
    sleep 1
done

echo "No USB rootfs found, booting from flash..."
ifconfig eth0 up
echo "Waiting for eth0 link..."
for i in 1 2 3 4 5; do
    if grep -q "1" /sys/class/net/eth0/carrier 2>/dev/null; then
        break
    fi
    sleep 1
done
udhcpc -i eth0
echo ""
echo "=============================="
echo " linux-chenxing on SSR621Q   "
echo " Boot (flash) successful!    "
echo "=============================="
echo ""
dropbear -R -p 22

# -------------------------------------------------------
# NAS: Mount USB SSD and start file-sharing services
# -------------------------------------------------------
NAS_MOUNT=/mnt/nas  # pre-exists in squashfs (rootfs-overlay/mnt/nas) - no RAM overhead
NAS_DEV=""

echo "Looking for NAS SSD..."
for dev in /dev/sda1 /dev/sdb1 /dev/sda2 /dev/sdb2; do
    if [ -b "$dev" ]; then
        # Skip any device already used as pivot-root
        if grep -q "$dev" /proc/mounts 2>/dev/null; then
            continue
        fi
        if mount "$dev" "$NAS_MOUNT" 2>/dev/null; then
            NAS_DEV="$dev"
            echo "NAS drive mounted: $dev -> $NAS_MOUNT"
            break
        fi
    fi
done

if [ -n "$NAS_DEV" ]; then
    # Create default storage directory
    mkdir -p "$NAS_MOUNT/files"

    # Start FTP server (BusyBox built-in, read-write access)
    if command -v tcpsvd >/dev/null 2>&1 && command -v ftpd >/dev/null 2>&1; then
        tcpsvd -E 0.0.0.0 21 ftpd -w "$NAS_MOUNT/files" &
        echo "FTP server started on port 21 (root: $NAS_MOUNT/files)"
    fi

    # Start HTTP file browser (BusyBox built-in httpd)
    if command -v httpd >/dev/null 2>&1; then
        mkdir -p "$NAS_MOUNT/www"
        # Generate a simple CGI directory listing page (unquoted CGEOF lets ${NAS_MOUNT} expand)
        if [ ! -f "$NAS_MOUNT/www/index.cgi" ]; then
            cat > "$NAS_MOUNT/www/index.cgi" << CGEOF
#!/bin/sh
echo "Content-type: text/html"
echo ""
echo "<html><head><title>NVR NAS</title>"
echo "<style>body{font-family:monospace;background:#111;color:#0f0;padding:20px}</style>"
echo "</head><body>"
echo "<h2>NVR NAS File Browser</h2><pre>"
ls -lh "${NAS_MOUNT}/files/"
echo "</pre></body></html>"
CGEOF
            chmod +x "$NAS_MOUNT/www/index.cgi"
        fi
        httpd -p 8080 -h "$NAS_MOUNT/www" &
        echo "HTTP file browser started on port 8080"
    fi

    # Export NFS share (requires CONFIG_NFSD=y in kernel)
    if [ -d /proc/fs/nfsd ] || modprobe nfsd 2>/dev/null; then
        EXPORTS_LINE="$NAS_MOUNT/files *(rw,sync,no_subtree_check,no_root_squash)"
        if ! echo "$EXPORTS_LINE" > /etc/exports 2>/dev/null; then
            # /etc is read-only (flash boot) - write to tmpfs and bind-mount over /etc/exports
            echo "$EXPORTS_LINE" > /tmp/nfs_exports
            if ! mount --bind /tmp/nfs_exports /etc/exports 2>/dev/null; then
                echo "Warning: could not write /etc/exports, NFS export skipped"
            fi
        fi
        if command -v exportfs >/dev/null 2>&1; then
            exportfs -ra
            echo "NFS export configured: $NAS_MOUNT/files"
        fi
    fi

    echo ""
    echo "=============================="
    echo " NAS services running         "
    echo " FTP  : port 21               "
    echo " HTTP : port 8080             "
    echo " SSH  : port 22 (sftp works)  "
    echo " NAS  : $NAS_MOUNT            "
    echo "=============================="
else
    echo "No NAS SSD found, skipping NAS services."
fi
# -------------------------------------------------------

# Hand PID 1 over to BusyBox init so it can handle respawn, reboot and shutdown.
exec /sbin/init
